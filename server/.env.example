PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/dating_app
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173

# Email — production (recommended on Render free tier): Resend HTTP API (no SMTP ports).
# Get your key at https://resend.com/api-keys — replace re_xxxxxxxxx with your real key.
RESEND_API_KEY=re_xxxxxxxxx
# Testing: onboarding@resend.dev (only sends to your Resend account email until domain verified).
# Production: verify domain at resend.com/domains, then e.g. MemberDate <noreply@memberdate.com>
RESEND_FROM="MemberDate <onboarding@resend.dev>"

# Optional fallback / local dev: SMTP (blocked on Render FREE — use Resend instead).
# Mailtrap sandbox: use port 2525 or 587 (avoid 25 — often blocked).
SMTP_HOST=
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MemberDate <noreply@yourdomain.com>"

# Development: Nodemailer sends verification mail via Ethereal (free fake inbox) and prints a preview URL.
# Set to true to skip Ethereal and only log the 6-digit code to the terminal.
DISABLE_ETHEREAL_FALLBACK=false

# Optional: media uploads (use your own Cloudinary account; never commit real secrets).
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# NOWPayments (crypto coin purchases)
# Keys from client dashboard: https://account.nowpayments.io (production) or account-sandbox.nowpayments.io (test)
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret
# Legacy aliases (still supported):
# API_KEY=your_nowpayments_api_key
# IPN_KEY=your_nowpayments_ipn_secret

# --- PRODUCTION (real payments) ---
NOWPAYMENTS_SANDBOX=false
CLIENT_ORIGIN=https://your-frontend.vercel.app
API_PUBLIC_URL=https://your-api-domain.com
NOWPAYMENTS_SUCCESS_URL=https://your-frontend.vercel.app/man/wallet?payment=success
NOWPAYMENTS_CANCEL_URL=https://your-frontend.vercel.app/man/wallet?payment=cancelled

# --- LOCAL TEST with ngrok (production keys + real crypto) ---
# 1. Run: ngrok http 5001
# 2. Set API_PUBLIC_URL to the ngrok HTTPS URL (no trailing slash)
# 3. Set VITE_API_URL on Vercel (or .env.local) to the same ngrok URL + /api path is auto — use full ngrok origin
# 4. Send client the webhook URL printed on server start: {API_PUBLIC_URL}/api/payments/webhook
# NOWPAYMENTS_SANDBOX=false
# API_PUBLIC_URL=https://xxxx.ngrok-free.dev

# --- SANDBOX only (fake payments, no real money) ---
# NOWPAYMENTS_SANDBOX=true
# NOWPAYMENTS_API_URL=https://api-sandbox.nowpayments.io/v1

# Video calls: coins charged from men to women each minute (default 10)
# VIDEO_CALL_COINS_PER_MINUTE=10